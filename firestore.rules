rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAssigned(siteId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/sites/$(siteId)) &&
             request.auth.uid in get(/databases/$(database)/documents/sites/$(siteId)).data.assignedUsers;
    }

    // NOTE: user profiles + the active/suspended `status` flag now live in the Realtime
    // Database (see database.rules.json), not here — Firestore rules can't read another
    // database, so they can no longer gate writes on that status directly. The primary
    // enforcement of a suspended account is the login-time check in js/auth.js and
    // js/user.js. As defense in depth, also unassign a suspended user's sites (Sites →
    // Assign users) so isAssigned() below stops passing for them immediately, even if
    // their existing ID token is still valid.

    // ---------- Admin allowlist ----------
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // console only — also mirror any change into RTDB admins/{uid}
    }

    // ---------- Sites ----------
    match /sites/{siteId} {
      allow read: if true; // public read so the loader script works without login
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isAssigned(siteId);

      match /versions/{versionId} {
        allow read: if isAdmin() || isAssigned(siteId);
        allow create: if isAdmin() || isAssigned(siteId);
        // Only the version currently flagged latest (unlocked) may be updated in place.
        allow update: if (isAdmin() || isAssigned(siteId)) && resource.data.locked == false;
        allow delete: if false; // history is permanent
      }
    }

    // ---------- Action logs (admin-only visibility) ----------
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // any signed-in actor can write a log entry of their own action
      allow update, delete: if false;
    }

    // ---------- 1:1 admin <-> user chat ----------
    // Thread id == the non-admin user's uid.
    match /chats/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      match /messages/{msgId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow create: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow update, delete: if false;
      }
    }

    // ---------- Groups (admin-created, multi-user) ----------
    match /groups/{groupId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.members);
      allow create, update, delete: if isAdmin(); // only admin manages membership

      match /messages/{msgId} {
        allow read: if isAdmin() ||
                       (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members);
        allow create: if isAdmin() ||
                       (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members);
        allow update, delete: if false;
      }
    }

    // ---------- Requests to chat with another user ----------
    match /chatRequests/{reqId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.fromUid);
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAdmin(); // only admin approves/denies
      allow delete: if isAdmin();
    }
  }
}
